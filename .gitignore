# Dependencies
node_modules/

# Environment / secrets
.env
.env.local
*.local

# Runtime data (SQLite db, logs) — never commit user data or secrets
data/*.db
data/*.db-*
data/*.sqlite
data/*.sqlite-*
logs/
*.log

# Playwright / browser downloads (browsers are provided by the host image)
.cache/
playwright-report/
test-results/

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# VS Code: ignore personal/local files but keep the shared, checked-in configs
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
