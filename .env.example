# ─────────────────────────────────────────────────────────────────────────────
# Hype Drop — configuration
# Copy this file to ".env" and fill in the values. Never commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Web server ───────────────────────────────────────────────────────────────
# Port the Node process listens on (nginx/caddy proxies to this).
PORT=3000
# Bind address. 127.0.0.1 keeps it private behind a reverse proxy (recommended).
# Use 0.0.0.0 only if you are exposing the app directly.
HOST=127.0.0.1

# Secret used to sign session cookies. MUST be long & random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to 1 when the app runs behind a TLS-terminating reverse proxy (nginx/caddy).
# This makes session cookies "Secure" and trusts the X-Forwarded-* headers.
TRUST_PROXY=0
# Force "Secure" cookies (usually auto: on when TRUST_PROXY=1). 0/1.
COOKIE_SECURE=0

# Public base URL of the site (used in emails / links). No trailing slash.
PUBLIC_BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically).
DATABASE_PATH=./data/hype-drop.db

# ── Monitoring defaults (also editable live in the admin panel) ──────────────
# Seconds between checks of each target.
CHECK_INTERVAL_SECONDS=60
# Random +/- jitter (seconds) added to the interval so requests aren't perfectly
# periodic (helps avoid bot fingerprinting). 0 disables jitter.
CHECK_JITTER_SECONDS=15
# Minimum seconds between repeated "queue started" alerts for the same target.
ALERT_COOLDOWN_SECONDS=900
# Detection strategy: "browser" (real Chromium, needed for bot-protected sites),
# "http" (fast, header-based fetch — usually blocked by Pokémon Center), or
# "auto" (try http first, fall back to browser).
CHECK_STRATEGY=browser
# Per-check navigation timeout in milliseconds.
CHECK_TIMEOUT_MS=30000
# User-Agent used by the checker. Leave blank to use a sane modern default.
CHECK_USER_AGENT=

# Comma-separated URLs to seed on first run (you can manage these in the UI later).
SEED_TARGETS=https://www.pokemoncenter.com/

# ── Email / SMTP (optional but required for email alerts) ────────────────────
# Any SMTP provider works: Gmail (with an App Password), SendGrid, Mailgun,
# Amazon SES, Postmark, your own mail server, etc.
#
# Gmail example (recommended: create an "App Password", NOT your login password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=1
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   MAIL_FROM="Hype Drop <youraddress@gmail.com>"
#
# Leave SMTP_HOST blank to disable email (on-site notifications still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ── First-run admin bootstrap (optional) ─────────────────────────────────────
# If set AND no users exist yet, an admin account is created automatically on
# startup. Otherwise create one with:  npm run create-admin
# (You can also do first-run setup in the browser at /setup.)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=
